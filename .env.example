# MailCue Configuration
# Copy to .env and customize as needed

# Domain for email addresses (user@DOMAIN)
MAILCUE_DOMAIN=mailcue.local

# Default admin account
MAILCUE_ADMIN_USER=admin
MAILCUE_ADMIN_PASSWORD=mailcue

# JWT secret key (leave empty to auto-generate at first boot)
MAILCUE_SECRET_KEY=

# SQLCipher encryption key for the SQLite database (AES-256 at rest).
# Leave empty to use unencrypted SQLite (default).
# When set on an existing unencrypted DB, it will be auto-converted on next startup.
MAILCUE_DATABASE_ENCRYPTION_KEY=

# IMAP master user (used by API to access all mailboxes)
MAILCUE_IMAP_MASTER_USER=mailcue-master
MAILCUE_IMAP_MASTER_PASSWORD=master-secret
